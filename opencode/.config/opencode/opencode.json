      }
    },
    "CopilotKit MCP": {
      "type": "remote",
      "url": "https://mcp.copilotkit.ai",
      "enabled": true
    },
    "Linear-mcp": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    }
  },
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "agent": {
    "build": {
      "mode": "primary",
      "model": "github-copilot/gpt-5-mini",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "plan": {
      "mode": "primary",
      "model": "github-copilot/gpt-4.1",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "chat": {
      "description": "Conversational mode for discussing code, libraries, and ideas informally.",
      "model": "github-copilot/gpt-5.2",
      "prompt": "You are a technical discussion partner. Ask clarifying questions about code, explain libraries, design patterns, or syntax, and maintain a curious, analytical tone.",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  },
  "plugin": ["oh-my-openagent", "opencode-wakatime"],
  "provider": {}
