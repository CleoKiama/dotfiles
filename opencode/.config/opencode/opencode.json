{
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-e32d5ee2-c8f3-4738-b112-7a0d97d9ce7f"
      }
    },
    "CopilotKit MCP": {
      "type": "remote",
      "url": "https://mcp.copilotkit.ai",
      "enabled": true
    },
    "Linear-mcp": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    }
  },
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "allow",
      "*.env.*": "allow",
      "*.env.example": "allow"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "github-copilot/gpt-5-mini",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "plan": {
      "mode": "primary",
      "model": "github-copilot/gpt-4.1",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "chat": {
      "description": "Casual conversation, explanations, and learning - no code changes",
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.7,
      "fallback_models": ["opencode/big-pickle", "opencode/minimax-m2.5-free"],
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny"
      }
    },
    "teacher": {
      "description": "Patient tutor for learning concepts, debugging explanations, best practices",
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.5,
      // big-pickle ok here: teacher is read-only, low tool call risk.
      "fallback_models": ["github-copilot/claude-sonnet-4.6", "opencode/big-pickle"],
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    }
  },
  "plugin": ["oh-my-openagent", "opencode-wakatime"],
  "provider": {}
}
