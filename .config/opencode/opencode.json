{
  "$schema": "https://opencode.ai/config.json",
  "formatter": true,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{file:~/.config/opencode/context7-key}"
      }
    },
    "Linear-mcp": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/linear-key}"
      }
    },
    "axiom": {
      "type": "remote",
      "url": "https://mcp.axiom.co/mcp",
      "enabled": true
    },
    "codebase-memory-mcp": {
      "enabled": true,
      "type": "local",
      "command": [
        "codebase-memory-mcp"
      ]
    }
  },
  "autoupdate": false,
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "allow",
      "*.env.*": "allow",
      "*.env.example": "allow"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "github-copilot/gpt-5-mini",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "plan": {
      "mode": "primary",
      "model": "github-copilot/gpt-4.1",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "chat": {
      "description": "Casual conversation, explanations, and learning - no code changes",
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.7,
      "fallback_models": [
        "opencode/big-pickle",
        "opencode/minimax-m2.5-free"
      ],
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny"
      }
    },
    "teacher": {
      "description": "Patient tutor for learning concepts, debugging explanations, best practices",
      "model": "opencode/mimo-v2.5-free",
      "temperature": 0.5,
      "fallback_models": [
        "github-copilot/claude-sonnet-4.6",
        "opencode/big-pickle"
      ],
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "plugin": [
    "opencode-wakatime",
    "oh-my-opencode-slim"
  ],
  "provider": {},
  "lsp": true
}
