# Fonts
font-family = "Hasklug Nerd Font Mono Med"
#font-family = "CaskaydiaCove Nerd Font"
font-family-bold = "CaskaydiaCove Nerd Font"
font-family-italic = "CaskaydiaCove Nerd Font"
font-family-bold-italic = "CaskaydiaCove Nerd Font"
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic

font-size = 13

font-thicken = false
font-feature = dlig
font-feature = calt
font-feature = liga
font-feature = dlig
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss20
font-feature = zero
font-feature = onum
bold-is-bright = true

adjust-underline-position = 6
adjust-cell-width = 0%
# normal for my laptop screen
adjust-cell-height = 20%
# bigger union tv 
#adjust-cell-height = 8%
adjust-underline-thickness = 40%
adjust-cursor-thickness = 150%

background-opacity = 0.92
# background-opacity-cells = true
cursor-color = #f94dff
#cursor-color = "#F8F8F2" # white

theme = Catppuccin Mocha


app-notifications = no-clipboard-copy

# clipboard read and write
clipboard-read = allow
clipboard-write = allow

window-decoration = false

# performance
quit-after-last-window-closed = true
quit-after-last-window-closed-delay = 5m

#gtk-single-instance = true
