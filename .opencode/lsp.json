{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/lsp-tools-mcp/main/schema.json",
  "lsp": {
    "typescript": {
      "command": ["/home/cleo/.local/share/nvim/mason/bin/typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx"],
      "priority": 10,
      "env": { "NODE_OPTIONS": "--max-old-space-size=4096" },
      "initialization": {
        "preferences": { "includeInlayParameterNameHints": "all" }
      }
    }
  }
}
